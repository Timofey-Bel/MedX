        .context-menu-item .material-icons {
            position: absolute;
            left: 4px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 18px;
        }
        
        .context-menu-separator {
            height: 1px;
            background: #d7d7d7;
            margin: 2px 0;
        }
