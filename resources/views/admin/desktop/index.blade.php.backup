                            store.load();
                        } else {
                            Ext.Msg.alert('Ошибка', result.message);
                        }
                    },
                    failure: function() {
                        Ext.Msg.alert('Ошибка', 'Ошибка удаления баннера');
                    }
                });
            }
        });
    }

