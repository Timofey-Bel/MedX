        /* Контекстное меню - Windows 10 Style */
        .context-menu {
            position: fixed;
            background: #f0f0f0;
            border: 1px solid #999;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
            min-width: 200px;
            z-index: 100001;
            display: none;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 12px;
            padding: 2px 0;
        }
        
        .context-menu.show {
            display: block;
        }
        
        .context-menu-item {
            padding: 6px 32px 6px 28px;
            cursor: pointer;
            color: #000;
            position: relative;
